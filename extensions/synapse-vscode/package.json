{
  "name": "synapse-mnm",
  "displayName": "Synapse (.mnm) Syntax",
  "description": "Syntax highlighting for Synapse memory configuration language (.mnm)",
  "version": "0.1.1",
  "icon": "logo.png",
  "publisher": "krypticmouse",
  "repository": "https://github.com/krypticmouse/synapse",
  "license": "MIT",
  "author": "krypticmouse",
  "bugs": "https://github.com/krypticmouse/synapse/issues",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [
      {
        "id": "mnm",
        "aliases": ["Synapse", "mnm"],
        "extensions": [".mnm"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "mnm",
        "scopeName": "source.mnm",
        "path": "./syntaxes/mnm.tmLanguage.json"
      }
    ]
  }
}
